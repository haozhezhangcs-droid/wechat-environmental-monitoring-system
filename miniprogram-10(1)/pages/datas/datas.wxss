/**index.wxss**/
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #81b5e9;
  box-sizing: border-box;
  padding: 20px;
}
/* 文字样式 */
.profile-pic {
  width: 150px;
  height: 150px;
  border-radius: 50%;
  margin-bottom: 0px;
}
/* 描述文字样式 */
.profile-info text {
  color: #b63b3b;
  font-size: 18px;
  font-weight: bold;
  text-align: center;
  margin: 5px 0;
  margin: 0; /* 或者根据需要自定义 */
  padding: 0; /* 可以减少内边距 */
  text-align: center; /* 保证文字居中 */
}

/* 文字描述样式 */
.description {
  margin-top: 2px;
}
.description text {
  color: #97177c; /* 蓝色字体 */
  font-size: 20px; /* 字体大小 */
  text-align: center; /* 居中对齐 */
  line-height: 1.6; /* 行高 */
  margin-top: 0px; /* 与上方内容间距 */
  padding: 0 15px;
}
/* 标题样式 */
.header {
  margin-bottom: 20px;
}

.title {
  font-size: 24px;
  font-weight: bold;
  color: rgb(104, 57, 57);
}

/* 轮播图样式 */
.swiper {
  width: 150%;
  height: 700px;
  margin-bottom: 2px;
  border-radius: 8px;
  overflow: hidden;

  /* 添加阴影效果 */
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  
  /* 添加渐变背景 */
  background: linear-gradient(45deg, #ff7e5f, #feb47b);

  /* 添加边框 */
  border: 2px solid #ff4d4f; /* 可自定义边框颜色 */
}


.swiper image {
  width: 100%;
  height: 100%;
}

/* 文本项样式 */
.content {
  display: flex;
  gap: 10px;
  margin-bottom: 0px;
  margin-top: 40px;
}

.item {
  border: 1px solid rgb(175, 28, 28);
  padding: 8px 16px;
  text-align: center;
  border-radius: 4px;
  background-color: rgb(158, 15, 15);
  color: rgb(228, 209, 209);
}

/* 按钮样式 */
.action-button {
  padding: 10px 20px;
  font-size: 16px;
  color: rgb(20, 17, 192);
  background-color: #1aad19;
  border-radius: 5px;
}
